# Frontend (Vite) — used when running `npm run build`
# Point this at your deployed Vercel backend URL.
VITE_API_BASE_URL=https://YOUR-VERCEL-DEPLOYMENT.vercel.app/api

# Firebase web config (same as .env, must be exposed to the client build)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
